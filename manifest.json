{
  "manifest_version": 2,
  "name": "PageGrep",
  "version": "1.4",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg",
    "128": "icons/icon-128.svg"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "shared/storage-keys.js",  // defines STORAGE_KEYS; must be first
      "background/background.js" // uses STORAGE_KEYS
    ],
    "persistent": false
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.svg",
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg",
      "128": "icons/icon-128.svg"
    },
    "default_title": "PageGrep"
  },
  "sidebar_action": {
    "default_title": "PageGrep",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": {
      "48": "icons/icon-48.svg"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-reader-helper@local",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "shared/storage-keys.js",  // defines STORAGE_KEYS; must be first
        "shared/theme-utils.js",   // defines isThemeDark(); no dependencies
        "shared/i18n-override.js", // uses STORAGE_KEYS; requires storage-keys.js
        "content/content.js"       // uses STORAGE_KEYS, isThemeDark, applyI18nOverride
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ]
}
